# ============================================
# Knox Message Receiver Server - Configuration
# ============================================

# --- Server ---
API_PORT=3000
PROXY_PORT=6000

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_PORT=6001

# --- Knox API ---
KNOX_API_BASE_URL=https://openapi.samsung.net
KNOX_ACCESS_TOKEN=your-access-token-here
KNOX_SYSTEM_ID=C60LD0001
KNOX_DEVICE_ID=                # device reg API로 획득 후 설정
KNOX_ENCRYPTION_KEY=           # getkeys API로 획득 후 설정

# --- Bot Communication ---
BOT_API_KEY=your-shared-secret-key-here    # Message Server ↔ Nexus Bot 인증

# --- Corporate Proxy ---
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.samsungds.net,redis,api-blue,api-green,nginx
